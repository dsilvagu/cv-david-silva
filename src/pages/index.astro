---
import '../../input.css'
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>David Alejandro Silva Gutiérrez</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
  		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  		<link href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,500;0,700;0,800;1,500;1,700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
	</head>
	<body class="bg-[#0A0A0B] text-[#EDE4ED] font-sans">
		<div class="max-w-[1100px] mx-auto px-4 sm:px-6 pb-16">
			<!--Navbar -->
			<div class="bg-[#151517] rounded-[18px] flex items-center justify-between px-5 sm:px-8 py-4 sm:py-5 mb-4">
				<p class="font-[Archivo] text-lg tracking-tight">
					<span class="italic font-medium">DAVID</span><span class="font-extrabold">ALEJANDRO</span>
				</p>

				<div class="hidden sm:flex gap-8 font-[JetBrains_Mono] text-[11px] tracking-widest text-neutral-400">
					<a href="#perfil" class="hover:text-[#EDEDED] transition-colors">PERFIL</a>
					<a href="#experiencia" class="hover:text-[#EDEDED] transition-colors">EXPERIENCIA</a>
					<a href="#proyectos" class="hover:text-[#EDEDED] transition-colors">PROYECTOS</a>
					<a href="#contacto" class="hover:text-[#EDEDED] transition-colors">CONTACTO</a>
				</div>
			</div>

			<!-- Hero -->
			<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
			<div id="perfil" class="md:col-span-2 bg-[#151517] rounded-[18px] p-6 sm:p-10 flex flex-col md:h-full">
				<p class="font-[JetBrains_Mono] text-[10px] sm:text-[11px] tracking-widest text-neutral-500">
				INGENIERO DE SISTEMAS — PIURA, PERÚ
				</p>
				<h1 class="font-[Archivo] font-extrabold text-[40px] sm:text-[52px] md:text-[64px] leading-[0.95] uppercase mt-3">
				David Alejandro<br />Silva Gutiérrez
				</h1>

				<div class="flex gap-6 sm:gap-10 mt-6 flex-wrap">
				<div>
					<p class="font-[Archivo] font-extrabold text-2xl">3+</p>
					<p class="font-[JetBrains_Mono] text-[10px] tracking-widest text-neutral-500">AÑOS EN GORE PIURA</p>
				</div>
				<div>
					<p class="font-[Archivo] font-extrabold text-2xl">2</p>
					<p class="font-[JetBrains_Mono] text-[10px] tracking-widest text-neutral-500">SISTEMAS EN PRODUCCIÓN</p>
				</div>
				</div>

				<div class="mt-6 md:mt-auto pt-6 border-t border-neutral-800">
				<p class="font-[Archivo] italic font-medium text-[16px] sm:text-[18px] md:text-[20px] leading-snug text-neutral-200 max-w-[560px]">
					"Diseño y mantengo sistemas que operan las 24 horas — desde el despacho de agua hasta
					plataformas de monitoreo electoral. Me interesa la precisión: que cada sistema haga
					exactamente lo que tiene que hacer, sin fallos."
				</p>
				<p class="font-[JetBrains_Mono] text-[10px] sm:text-[11px] tracking-widest text-neutral-500 mt-3">
					PHP · MYSQL · TAILWIND CSS · ADMINLTE · GIT · ASTRO
				</p>
				</div>
			</div>

			<div class="col-span-1 flex flex-col gap-4">
				<div
					class="rounded-[18px] min-h-[220px] sm:min-h-[280px] md:min-h-0 md:flex-1 bg-cover bg-center grayscale"
					style="background-image: url('/foto.jpg');"
				></div>
				<div class="bg-[#151517] rounded-[18px] p-5 flex items-center justify-between">
				<p class="font-[Archivo] font-extrabold text-3xl">24/7</p>
				<p class="font-[JetBrains_Mono] text-[10px] tracking-widest text-neutral-500 text-right leading-tight">
					SISTEMAS<br />EN OPERACIÓN
				</p>
				</div>
			</div>
			</div>

			<!--Experiencia -->
			<div id="experiencia" class="bg-[#151517] rounded-[18px] p-6 sm:p-9 mb-4">
				<p class="font-[Archivo] font-extrabold text-2xl uppercase mb-6">Experiencia</p>
				<div class="grid grid-cols-1 md:grid-cols-[110px_1fr] gap-x-6 gap-y-2 md:gap-y-6">
					<p class="font-[JetBrains_Mono] text-[11px] text-neutral-500 pt-1">
						set. 2023 - jun. 2026
					</p>
					<div class="pb-6 border-b border-neutral-800">
						<p class="font-medium text-[16px]">Ingeniero de Sistemas</p>
						<p class="italic text-sm text-neutral-400 mb-2">Centro de Abastecimiento de Agua Bayóvar - GORE Piura</p>
						<p class="text-[13px] text-neutral-400 leading-relaxed">
							Desarrollo y mantenimiento de SISCAAB, sistema de despacho de agua 24/7: dashboards con AdminLTE, generación de reportes en PDF y gestión de base de datos.
						</p>
					</div>

					<p class="font-[JetBrains_Mono] text-[11px] text-neutral-500 pt-1 mt-4 md:mt-0">
						jul. 2022 - may. 2023
					</p>
					<div class="pb-6 border-b border-neutral-800">
						<p class="font-medium text-[16px]">Maquetador de Correos HTML</p>
						<p class="italic text-sm text-neutral-400 mb-2">Bronca Systems INC</p>
						<p class="text-[13px] text-neutral-400 leading-relaxed">
							Programación y maquetación de plantillas de correo electrónico en HTML, listas para que otras áreas de la empresa las utitilizaran en sus campañas de envío.
						</p>
					</div>

					<p class="font-[JetBrains_Mono] text-[11px] text-neutral-500 pt-1 mt-4 md:mt-0">
						may. 2022 - jul. 2023
					</p>
					<div>
						<p class="font-medium text-[16px]">Ingeniero de Sistemas</p>
						<p class="italic text-sm text-neutral-400 mb-2">Ekonodrywall · Dagos Store</p>
						<p class="text-[13px] text-neutral-400 leading-relaxed">
							Desarrollo de un sistema de ventas y almacén en Ekonodrywall, junto con una aplicación
                            iOS que permitía a los usuarios visualizar en 3D los materiales de venta.
						</p>
					</div>
				</div>
			</div>

			<!--Educación / Habilidades / Contacto -->
			<div class="grid grid-cols-1 sm:grid-cols-3 gap-6 sm:gap-4 mb-4 px-6 sm:px-9">
				<div class="col-span-1">
					<p class="font-[JetBrains_Mono] text-[10px] tracking-widest text-neutral-500 mb-2" >EDUCACIÓN</p>
					<p class="text-[14px] font-medium">Ing. de Sistemas</p>
					<p class="text-[13px] text-neutral-400">Universidad César Vallejo · Tercio superior</p>
					<p class="text-[13px] text-neutral-400 mt-2">IDAT · Técnico en informática</p>
				</div>

				<div class="col-span-1">
					<p class="font-[JetBrains_Mono] text-[10px] tracking-widest text-neutral-500 mb-2">HABILIDADES</p>
					<p class="text-[13px] text-neutral-300 leading-relaxed">PHP / MySQL (MVC) · AdminLTE · DataTables · JavaScript · Tailwind CSS · PDF &amp; Code128 · Git
					</p>
				</div>
				<div id="contacto" class="col-span-1">
					<p class="font-[JetBrains_Mono] text-[10px] tracking-widest text-neutral-500 mb-2">CONTACTO</p>
					<p class="text-[13px] text-neutral-300 leading-relaxed">
						dasg2506@icloud.com<br />+51 930 830 373<br />
					</p>
				</div>
			</div>

			<!--Proyectos -->
			<div id="proyectos" class="grid grid-cols-1 md:grid-cols-3 gap-4">
				<div class="md:col-span-2 relative rounded-[18px] overflow-hidden min-h-[280px] sm:min-h-[320px]">
					<img
						src="/personerospiura.jpg"
						alt="Dashboard de PersonerosPiura 2026"
						class="absolute inset-0 w-full h-full object-cover object-top"
					/>
					<div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/40 to-transparent"></div>
					<div class="relative h-full flex flex-col justify-end p-6 sm:p-8">
						<p class="font-[JetBrains_Mono] text-[10px] tracking-widest text-neutral-300">
							PHP · MYSQL · ELECCIONES REGIONALES 2026
						</p>
						<p class="font-[Archivo] font-extrabold text-3xl sm:text-4xl leading-none mt-2 mb-2 text-white">
							PersonerosPiura
						</p>
						<p class="text-[13px] text-neutral-200 max-w-[420px]">
							Plataforma de monitoreo electoral con jerarquía geográfica de 4 niveles, flujo de personero de 3 pantallas y panel de resultados en tiempo real.
						</p>
					</div>
				</div>

				<div class="col-span-1 relative rounded-[18px] overflow-hidden min-h-[280px] sm:min-h-[320px]">
					<img
						src="/siscaab.jpg"
						alt="Dashboard de SISCAAB"
						class="absolute inset-0 w-full h-full object-cover object-top"
					/>
					<div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/40 to-transparent"></div>
					<div class="relative h-full flex flex-col justify-end p-6 sm:p-7">
						<p class="font-[JetBrains_Mono] text-[10px] tracking-widest text-neutral-300">24/7 · GORE PIURA</p>
						<p class="font-[Archivo] font-extrabold text-2xl leading-none mt-2 text-white">SISCAAB</p>
						<p class="text-[12px] text-neutral-200 mt-2">Sistema de despacho de agua operativo 24 horas.</p>
					</div>
				</div>
			</div>

		</div>
	</body>
</html>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>